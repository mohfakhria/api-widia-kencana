  "item": [
    {
      "name": "List Quotations",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/quotation-list?status=po&project=website",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "quotation-list"
          ],
          "query": [
            {
              "key": "status",
              "value": "po",
              "description": "Optional. Filter by status step token inside quotations.status, for example new, po, or sr."
            },
            {
              "key": "project",
              "value": "website",
              "description": "Optional. Case-insensitive partial match against project."
            }
          ]
        },
        "description": "Both query params are optional. Status is matched per token from colon-delimited values like new:po:sr."
      },
      "response": [
        {
          "name": "List Quotations - Success",
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "body": "{\n  \"status\": \"ok\",\n  \"message\": \"Success\",\n  \"data\": [\n    {\n      \"id\": 1,\n      \"quotation_no\": \"Q-2026-0001\",\n      \"client_name\": \"PT Contoh\",\n      \"project\": \"Website Revamp\",\n      \"status\": \"new:po\",\n      \"total\": 12000000\n    }\n  ]\n}"
        },
        {
